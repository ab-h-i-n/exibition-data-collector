# Google Apps Script Web App URL (the deployment URL ending in /exec).
# When set, the app auto-saves every lead to this Google Sheet — no need to
# paste the URL in the app's Settings on each device.
#
# The name MUST start with VITE_ so Vite exposes it to the browser app.
#
#   Local dev:  copy this file to  .env.local  and fill in your URL
#   Vercel:     add the same key/value in  Settings -> Environment Variables,
#               then Redeploy (Vite bakes env vars in at build time)
VITE_SHEET_ENDPOINT=https://script.google.com/macros/s/PASTE_YOUR_ID/exec
